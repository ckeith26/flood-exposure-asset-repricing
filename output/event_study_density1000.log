. replace ebin_m3 = 1 if event_bin == -3
(1,082 real changes made)

. replace ebin_m2 = 1 if event_bin == -2
(1,015 real changes made)

. * τ = -1 is OMITTED (reference)
. replace ebin_p0 = 1 if event_bin == 0
