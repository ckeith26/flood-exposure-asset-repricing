  4.     local intv : word `i' of `intvars'
  5.     qui lincom `v' + `intv'
  6.     replace coef  = r(estimate)                   if _n == `row'
  7.     replace ci_lo = r(estimate) - 1.96 * r(se)    if _n == `row'
  8.     replace ci_hi = r(estimate) + 1.96 * r(se)    if _n == `row'
  9.     local i = `i' + 1
 10. }
