
. clear all

. set more off

. set scheme s2color

. 
. * --- SAMPLE RESTRICTION ---
. * Set to 0 for full sample; >1000 = Census urban definition
. global density_min 0

. * Set to 0 for full sample; e.g. 10000 for thick housing markets
. global pop_min 0

. * Set to 0 for full time range; e.g. 2015 to restrict to post-2015
. global year_min 0

