. * --- Create quartile × event-time interaction dummies (32 total) ---
. foreach t in m4 m3 m2 p0 p1 p2 p3 p4 {
  2.     forvalues q = 1/4 {
  3.         gen ebin_`t'_q`q' = ebin_`t' * (intensity_quartile == `q')
  4.         label var ebin_`t'_q`q' "τ = `t' × Q`q'"
  5.     }
  6. }

