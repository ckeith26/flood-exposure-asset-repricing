. * Export C&S event study coefficients to CSV
. estimates restore cs_event
(results cs_event are active now)

. matrix b = e(b)

. matrix V = e(V)

. local k = colsof(b)

. tempname fh

. file open `fh' using "$results/s13_event_study_cs_coefficients.csv", write re
> place
(file /Users/cameronkeith/Desktop/Econ/Econ 66/Research
    Paper/econ66-fear/output/results_1000p/s13_event_study_cs_coefficients.cs
    > v not found)

. file write `fh' "tau,coef,se,ci_lo,ci_hi" _n

. local names : colnames b

. local i = 1

. foreach name of local names {
  2.     local coef = b[1,`i']
  3.     local se = sqrt(V[`i',`i'])
  4.     local ci_lo = `coef' - 1.96 * `se'
  5.     local ci_hi = `coef' + 1.96 * `se'
  6.     * Extract tau from column name (e.g., "Tp3" -> 3, "Tm2" -> -2)
.     local tau = subinstr("`name'", "Tp", "", .)
  7.     local tau = subinstr("`tau'", "Tm", "-", .)
  8.     local tau = subinstr("`tau'", "Pre_avg", "pre", .)
  9.     local tau = subinstr("`tau'", "Post_avg", "post", .)
 10.     file write `fh' "`tau',`coef',`se',`ci_lo',`ci_hi'" _n
 11.     local ++i
 12. }

. file close `fh'

. 
. restore

